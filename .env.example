# ============================================================
# VendorScout - Environment Configuration
# ============================================================
# Copy this file to .env and fill in your keys. NEVER commit .env.
# ============================================================

# ---------- LLM provider ----------
# PRIMARY (preferred): Azure OpenAI (Azure AI Foundry) — Microsoft AI stack.
# Set all four to route reasoning/planning through Azure OpenAI.
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
AZURE_OPENAI_API_KEY=your_azure_openai_key
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_OPENAI_API_VERSION=2024-10-21

# ALT PRIMARY / dev: any OpenAI-compatible endpoint (used if Azure is unset).
# LLM_API_KEY=your_llm_api_key
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_MODEL=gpt-4o

# FALLBACK (disclosed resilience): llm.lehana.in SMK proxy — used only if the
# primary provider call fails, so the live demo never hard-fails.
# LLM_SERVICE_URL=http://llm-service:8095
# LLM_SERVICE_ENDPOINT=vendorscout

# ---------- Web discovery ----------
# SerperDev Google Search (vendor discovery). Sign up at https://serper.dev
SERPER_API_KEY=your_serper_api_key

# ---------- Self-hosted Agentic Browser (Playwright) ----------
# After `pip install -r requirements.txt`, run `playwright install chromium`.
BROWSER_HEADLESS=true
BROWSER_MAX_CONCURRENCY=3
BROWSER_MAX_STEPS=12
# Confirm-before-send guard: keep false in production; demo accounts may set true.
BROWSER_ALLOW_AUTOSUBMIT=false

# ---------- App ----------
DATABASE_PATH=./data/vendorscout.db
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO
MAX_VENDORS_PER_JOB=30
SSE_KEEPALIVE_SECONDS=15
